# Verity extension config for `--env dev` (Vite mode "dev").
# The extension talks only to the verity-api gateway; app/RPC/chain config now
# lives in verity-api (server-side), not here.
VITE_VERITY_API_URL=http://localhost:8790

# Verisphere app API — called directly (via the worker) for passthrough calls.
VITE_APP_API_BASE=https://test.verisphere.co/api

# Data adapter: "mock" (self-contained) or "http" (live gateway).
VITE_API_MODE=http

# Where "Buy VSP" links when a connected wallet has none.
VITE_BUY_VSP_URL=https://test.verisphere.co
