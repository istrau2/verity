{
  "manifest_version": 3,
  "name": "Verity — Truth-staking for Wikipedia",
  "version": "0.1.0",
  "description": "Highlights stakeable factual claims on Wikipedia, shows their on-chain Verity Score, and lets you stake or create claims.",
  "action": {
    "default_title": "Verity",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.wikipedia.org/wiki/*"
      ],
      "js": [
        "src/content/index.tsx-loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*.wikipedia.org/*",
    "http://localhost:8070/*",
    "http://localhost:8790/*",
    "https://api.verisphere.example/*",
    "https://verity-api.verisphere.example/*",
    "https://verisphere.co/api/*",
    "https://test.verisphere.co/api/*"
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "**/*",
        "*"
      ],
      "use_dynamic_url": false
    }
  ]
}
