# Copy to .env.local (dev) / .env.production (prod). Vars must be VITE_-prefixed.

# Main Verisphere app backend (claims, relay, token, dedup).
VITE_APP_API_BASE=http://localhost:8070/api

# verity-api atomicity/decomposition service.
VITE_VERITY_API_URL=http://localhost:8790

# Data adapter: "mock" (self-contained demo) or "http" (real app backend).
VITE_API_MODE=mock
