# Copy to .env.dev / .env.production. Vars must be VITE_-prefixed.

# verity-api gateway (proxies the app + chain, runs atomicity). The extension
# talks only to this.
VITE_VERITY_API_URL=http://localhost:8790

# Verisphere app API — called directly (via the worker) for passthrough calls.
VITE_APP_API_BASE=https://test.verisphere.co/api

# Data adapter: "mock" (self-contained demo) or "http" (live gateway).
VITE_API_MODE=mock

# --- docker-compose.dev.yml (copy to `.env` next to this file) ---
# Not VITE_-prefixed. Containers cannot use localhost for host Postgres.
# DATABASE_URL=postgres://USER:PASS@host.docker.internal:5432/verity
